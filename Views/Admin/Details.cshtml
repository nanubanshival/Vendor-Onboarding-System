@model VendorOnboardingSystem.Models.Vendor
@using VendorOnboardingSystem.Data
@inject ApplicationDbContext _context

@{
    ViewData["Title"] = "Vendor Details";
}
@{
    var adminUsername = Context.Session.GetString("AdminUser");
    var currentAdmin = _context.AdminUsers.FirstOrDefault(a => a.Username == adminUsername);
    bool isSuperAdmin = currentAdmin?.IsSuperAdmin ?? false;
}
<div class="container py-4">

    <!-- Header -->
    <div class="page-head d-flex justify-content-between align-items-end gap-3">
        <div>
            <span class="micro-label d-block mb-1">Vendor Profile</span>
            <h2 class="ds-h" style="font-size:1.85rem;">Application <em style="font-style:italic;color:var(--brand-accent);font-weight:400;">Review</em></h2>
            <p class="lead mt-1">Reference: <span class="fw-semibold" style="color:var(--brand-text);">@Model.ReferenceNumber</span> · @Model.LegalName</p>
        </div>

        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>


    <!-- Status Section -->
    <div class="brand-panel mb-4" style="padding:1.1rem 1.25rem;">
        <div class="row align-items-center">

            <div class="col-md-3">
                <div class="text-muted small">STATUS</div>

                @if (Model.Status == "Pending")
                {
                    <span class="status-chip chip-pending">Pending Review</span>
                }
                else if (Model.Status == "Approved")
                {
                    <span class="status-chip chip-ok">Approved</span>
                }
                else if (Model.Status == "Changes Submitted")
                {
                    <span class="status-chip chip-ok">Review Changes</span>
                }
                else if (Model.Status == "Changes Requested")
                {
                    <span class="status-chip chip-pending">Changes Requested</span>
                }
                else if (Model.Status == "PendingSuperAdmin")
                {
                    <span class="status-chip chip-pending">Pending Super Admin</span>
                }
                else
                {
                    <span class="status-chip chip-rej">Rejected</span>
                }
            </div>

            <div class="col-md-3">
                <div class="text-muted small">VENDOR CODE</div>
                <div class="fw-semibold">@(Model.VendorCode ?? "Not assigned")</div>
            </div>

            <div class="col-md-3">
                <div class="text-muted small">SUBMITTED ON</div>
                <div class="fw-semibold">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
            </div>

            <div class="col-md-3">
                <div class="text-muted small">LAST UPDATED</div>
                <div class="fw-semibold">@(Model.UpdatedAt?.ToString("dd MMM yyyy") ?? "-")</div>
            </div>

        </div>

        @if (!string.IsNullOrEmpty(Model.RejectionReason))
        {
            <div class="alert alert-danger mt-3 mb-0 py-2">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Rejection Reason:</strong> @Model.RejectionReason
            </div>
        }
    </div>


    <div class="row g-4">

        <!-- LEFT COLUMN -->
        <div class="col-md-6">

            <!-- Legal Information -->
            <div class="card mb-3" style="overflow:hidden;">

                <div class="card-header px-3 py-2 fw-semibold text-primary">
                    <i class="bi bi-building me-2"></i>Legal Information
                </div>

                <div class="p-4">

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Legal Name</div>
                        <div class="col-7 fw-semibold">@Model.LegalName</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Trade Name</div>
                        <div class="col-7">@(Model.TradeName ?? "-")</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Vendor Type</div>
                        <div class="col-7">@Model.VendorType</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Category</div>
                        <div class="col-7">@Model.VendorCategory</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Constitution</div>
                        <div class="col-7">@Model.Constitution</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Incorporation Date</div>
                        <div class="col-7">@Model.DateOfIncorporation?.ToString("dd MMM yyyy")</div>
                    </div>

                    <div class="row">
                        <div class="col-5 text-muted">CIN</div>
                        <div class="col-7">@(Model.CIN ?? "-")</div>
                    </div>

                </div>

            </div>


            <!-- PAN Details -->
            <div class="card mb-3" style="overflow:hidden;">

                <div class="card-header px-3 py-2 fw-semibold text-warning">
                    <i class="bi bi-credit-card me-2"></i>PAN Details
                </div>

                <div class="p-4">

                    <div class="row mb-2">
                        <div class="col-5 text-muted">PAN Number</div>
                        <div class="col-7 fw-semibold">@Model.PAN</div>
                    </div>

                    <div class="row">
                        <div class="col-5 text-muted">PAN Document</div>

                        <div class="col-7">

                            @if (!string.IsNullOrEmpty(Model.PANCopyPath))
                            {
                                <a href="@Model.PANCopyPath" target="_blank" class="btn btn-sm btn-outline-primary">
                                    View
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">Not uploaded</span>
                            }

                        </div>
                    </div>

                </div>

            </div>


            <!-- GST Details -->
            <div class="card mb-3" style="overflow:hidden;">

                <div class="card-header px-3 py-2 fw-semibold text-success">
                    <i class="bi bi-truck me-2"></i>GST Details
                </div>

                <div class="p-4">

                    <div class="row mb-2">
                        <div class="col-5 text-muted">GST Registered</div>
                        <div class="col-7">@Model.GSTRegistered</div>
                    </div>

                    @if (Model.GSTRegistered == "Yes")
                    {

                        <div class="row mb-2">
                            <div class="col-5 text-muted">GSTIN</div>
                            <div class="col-7">@Model.GSTIN</div>
                        </div>

                        <div class="row">
                            <div class="col-5 text-muted">GST Certificate</div>

                            <div class="col-7">
                                @if (!string.IsNullOrEmpty(Model.GSTCertificatePath))
                                {
                                    <a href="@Model.GSTCertificatePath" target="_blank" class="btn btn-sm btn-outline-success">
                                        View
                                    </a>
                                }
                            </div>

                        </div>

                    }

                </div>

            </div>


            <!-- MSME Details -->
            <div class="card mb-3" style="overflow:hidden;">

                <div class="card-header px-3 py-2 fw-semibold text-info">
                    <i class="bi bi-building me-2"></i>MSME Details
                </div>

                <div class="p-4">

                    <div class="row mb-2">
                        <div class="col-5 text-muted">MSME Registered</div>
                        <div class="col-7">@Model.MSMERegistered</div>
                    </div>

                    @if (Model.MSMERegistered == "Yes")
                    {

                        <div class="row">
                            <div class="col-5 text-muted">Udyam Number</div>
                            <div class="col-7">@Model.UdyamNumber</div>
                        </div>

                    }

                </div>

            </div>


            <!-- TDS -->
            <div class="card mb-3" style="overflow:hidden;">

                <div class="card-header px-3 py-2 fw-semibold text-secondary">
                    <i class="bi bi-percent me-2"></i>TDS Details
                </div>

                <div class="p-4">

                    <div class="row mb-2">
                        <div class="col-5 text-muted">TDS Applicable</div>
                        <div class="col-7">@Model.TDSApplicable</div>
                    </div>

                    @if (Model.TDSApplicable == "Yes" && !string.IsNullOrEmpty(Model.TDSSections))
                    {

                        <div class="row">
                            <div class="col-5 text-muted">TDS Sections</div>

                            <div class="col-7">

                                @foreach (var item in Model.TDSSections.Split(','))
                                {
                                    <span class="badge bg-light text-dark border me-1">@item</span>
                                }

                            </div>

                        </div>

                    }

                </div>

            </div>

        </div>


        <!-- RIGHT COLUMN -->
        <div class="col-md-6">


            <!-- Bank -->
            <div class="card mb-3" style="overflow:hidden;">

                <div class="card-header px-3 py-2 fw-semibold text-primary">
                    <i class="bi bi-bank me-2"></i>Bank Details
                </div>

                <div class="p-4">

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Account Holder</div>
                        <div class="col-7 fw-semibold">@Model.AccountHolderName</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Bank Name</div>
                        <div class="col-7">@Model.BankName</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Account Number</div>
                        <div class="col-7">@Model.AccountNumber</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">IFSC Code</div>
                        <div class="col-7">@Model.IFSC</div>
                    </div>

                    <div class="row">
                        <div class="col-5 text-muted">Cancelled Cheque</div>

                        <div class="col-7">
                            @if (!string.IsNullOrEmpty(Model.CancelledChequePath))
                            {
                                <a href="@Model.CancelledChequePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                    View
                                </a>
                            }
                        </div>
                    </div>

                </div>

            </div>


            <!-- Address -->
            <div class="card mb-3" style="overflow:hidden;">

                <div class="card-header px-3 py-2 fw-semibold text-warning">
                    <i class="bi bi-geo-alt me-2"></i>Address Details
                </div>

                <div class="p-4">

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Address Line 1</div>
                        <div class="col-7">@Model.AddressLine1</div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.AddressLine2))
                    {

                        <div class="row mb-2">
                            <div class="col-5 text-muted">Address Line 2</div>
                            <div class="col-7">@Model.AddressLine2</div>
                        </div>

                    }

                    <div class="row mb-2">
                        <div class="col-5 text-muted">City</div>
                        <div class="col-7">@Model.City</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">State</div>
                        <div class="col-7">@Model.State</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">PIN Code</div>
                        <div class="col-7">@Model.PINCode</div>
                    </div>

                    <div class="row">
                        <div class="col-5 text-muted">Country</div>
                        <div class="col-7">@Model.Country</div>
                    </div>

                </div>

            </div>


            <!-- Contact -->
            <div class="card mb-3" style="overflow:hidden;">

                <div class="card-header px-3 py-2 fw-semibold text-success">
                    <i class="bi bi-person me-2"></i>Contact Information
                </div>

                <div class="p-4">

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Primary Contact</div>
                        <div class="col-7 fw-semibold">@Model.PrimaryContactName</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Designation</div>
                        <div class="col-7">@(Model.Designation ?? "-")</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Mobile</div>
                        <div class="col-7">@Model.MobileNumber</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Email</div>
                        <div class="col-7">@Model.Email</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Alternate Contact</div>
                        <div class="col-7">@(Model.AlternateContactPerson ?? "-")</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-5 text-muted">Aadhar Number</div>
                        <div class="col-7">@(Model.AadharNumber ?? "-")</div>
                    </div>

                    <div class="row">
                        <div class="col-5 text-muted">Aadhar Copy</div>

                        <div class="col-7">

                            @if (!string.IsNullOrEmpty(Model.AadharCopyPath))
                            {
                                <a href="@Model.AadharCopyPath" target="_blank" class="btn btn-sm btn-outline-primary">
                                    View
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">Not uploaded</span>
                            }

                        </div>
                    </div>

                </div>

            </div>

        </div>
    </div>


    @if (Model.Status == "Pending")
    {
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <div class="d-flex gap-3 flex-wrap">
                    <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#editRequestModal">
                        <i class="bi bi-pencil-square"></i> Request Edits
                    </button>

                    <form method="post" asp-action="Approve" asp-route-id="@Model.VendorId" class="d-inline">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Approve
                        </button>
                    </form>

                    <form method="post" asp-action="Reject" asp-route-id="@Model.VendorId" class="d-inline">
                        <input type="text" name="reason" class="form-control d-inline w-auto" placeholder="Rejection reason" required />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-x-circle"></i> Reject
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }

    else if (Model.Status == "Changes Submitted")
    {
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
            <div class="d-flex gap-3">
                <a href="/Admin/ReviewSubmittedEdits/@Model.VendorId" class="btn btn-warning">
                    <i class="bi bi-eye"></i> Review Submitted Changes
                </a>
            </div>
        </div>
    </div>
    }

    else if (Model.Status == "PendingSuperAdmin")
    {
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
            @if (isSuperAdmin)
            {
                <div class="d-flex gap-3 flex-wrap">
                    <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#editRequestModal">
                        <i class="bi bi-pencil-square"></i> Request Edits
                    </button>

                    <form method="post" asp-action="Approve" asp-route-id="@Model.VendorId" class="d-inline">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Final Approve
                        </button>
                    </form>

                    <form method="post" asp-action="Reject" asp-route-id="@Model.VendorId" class="d-inline">
                        <input type="text" name="reason" class="form-control d-inline w-auto" placeholder="Rejection reason" required />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-x-circle"></i> Reject
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    <i class="bi bi-info-circle"></i> This vendor is pending super admin approval. You cannot perform actions.
                </div>
            }
        </div>
    </div>
    }
</div>

<!-- Edit Request Modal -->
<div class="modal fade" id="editRequestModal" tabindex="-1" aria-labelledby="editRequestModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background:var(--brand-warning-bg);border-bottom-color:var(--brand-warning-border);">
                <h5 class="modal-title" style="color:var(--brand-warning-text);" id="editRequestModalLabel">
                    <i class="bi bi-pencil-square"></i> Request Edits from Vendor
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateEditRequest" asp-controller="Admin" method="post">
                <div class="modal-body">
                    <input type="hidden" name="VendorId" value="@Model.VendorId" />

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Select sections that need correction. Vendor will only see these sections.
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <!-- Legal Info -->
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Section 1: Legal Information</h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <!-- IMPORTANT: Use value="true" and checked binding -->
                                        <input class="form-check-input" type="checkbox" name="LegalInfo" value="true" id="chkLegalInfo">
                                        <input type="hidden" name="LegalInfo" value="false" />
                                        <label class="form-check-label fw-bold" for="chkLegalInfo">Legal Info needs changes</label>
                                    </div>
                                    <div class="mb-3 ms-4" id="legalInfoCommentDiv" style="display:none;">
                                        <textarea name="LegalInfoComment" class="form-control" rows="2" placeholder="What needs to be changed?"></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- PAN Details -->
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Section 2: PAN Details</h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="PANDetails" value="true" id="chkPANDetails">
                                        <input type="hidden" name="PANDetails" value="false" />
                                        <label class="form-check-label fw-bold" for="chkPANDetails">PAN needs changes</label>
                                    </div>
                                    <div class="mb-3 ms-4" id="panDetailsCommentDiv" style="display:none;">
                                        <textarea name="PANDetailsComment" class="form-control" rows="2" placeholder="What's wrong with PAN?"></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- GST Details -->
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Section 3: GST Details</h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="GSTDetails" value="true" id="chkGSTDetails">
                                        <input type="hidden" name="GSTDetails" value="false" />
                                        <label class="form-check-label fw-bold" for="chkGSTDetails">GST needs changes</label>
                                    </div>
                                    <div class="mb-3 ms-4" id="gstDetailsCommentDiv" style="display:none;">
                                        <textarea name="GSTDetailsComment" class="form-control" rows="2" placeholder="What's wrong with GST?"></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- MSME Details -->
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Section 4: MSME Details</h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="MSMEDetails" value="true" id="chkMSMEDetails">
                                        <input type="hidden" name="MSMEDetails" value="false" />
                                        <label class="form-check-label fw-bold" for="chkMSMEDetails">MSME needs changes</label>
                                    </div>
                                    <div class="mb-3 ms-4" id="msmeDetailsCommentDiv" style="display:none;">
                                        <textarea name="MSMEDetailsComment" class="form-control" rows="2" placeholder="What's wrong with MSME?"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <!-- TDS Details -->
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Section 5: TDS Details</h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="TDSDetails" value="true" id="chkTDSDetails">
                                        <input type="hidden" name="TDSDetails" value="false" />
                                        <label class="form-check-label fw-bold" for="chkTDSDetails">TDS needs changes</label>
                                    </div>
                                    <div class="mb-3 ms-4" id="tdsDetailsCommentDiv" style="display:none;">
                                        <textarea name="TDSDetailsComment" class="form-control" rows="2" placeholder="What's wrong with TDS?"></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Bank Details -->
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Section 6: Bank Details</h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="BankDetails" value="true" id="chkBankDetails">
                                        <input type="hidden" name="BankDetails" value="false" />
                                        <label class="form-check-label fw-bold" for="chkBankDetails">Bank needs changes</label>
                                    </div>
                                    <div class="mb-3 ms-4" id="bankDetailsCommentDiv" style="display:none;">
                                        <textarea name="BankDetailsComment" class="form-control" rows="2" placeholder="What's wrong with bank details?"></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Address Details -->
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Section 7: Address Details</h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="AddressDetails" value="true" id="chkAddressDetails">
                                        <input type="hidden" name="AddressDetails" value="false" />
                                        <label class="form-check-label fw-bold" for="chkAddressDetails">Address needs changes</label>
                                    </div>
                                    <div class="mb-3 ms-4" id="addressDetailsCommentDiv" style="display:none;">
                                        <textarea name="AddressDetailsComment" class="form-control" rows="2" placeholder="What's wrong with address?"></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Contact Details -->
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Section 8: Contact Information</h6>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="ContactDetails" value="true" id="chkContactDetails">
                                        <input type="hidden" name="ContactDetails" value="false" />
                                        <label class="form-check-label fw-bold" for="chkContactDetails">Contact needs changes</label>
                                    </div>
                                    <div class="mb-3 ms-4" id="contactDetailsCommentDiv" style="display:none;">
                                        <textarea name="ContactDetailsComment" class="form-control" rows="2" placeholder="What's wrong with contact?"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- General Comments -->
                    <div class="card mt-3">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">General Instructions (Required)</h6>
                        </div>
                        <div class="card-body">
                            <textarea name="Comments" class="form-control" rows="3" placeholder="Any additional instructions for vendor..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Send Edit Request</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Show/hide comment boxes when checkboxes are clicked
    document.getElementById('chkLegalInfo')?.addEventListener('change', function() {
