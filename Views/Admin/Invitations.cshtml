@model IEnumerable<VendorOnboardingSystem.Models.RegistrationInvitation>

@{
    ViewData["Title"] = "Registration Invitations";
}

<div class="page-head d-flex justify-content-between align-items-end gap-3">
    <div>
        <span class="micro-label d-block mb-1">Registration Pipeline</span>
        <h2 class="ds-h" style="font-size:1.85rem;">All <em style="font-style:italic;color:var(--brand-accent);font-weight:400;">Invitations</em></h2>
        <p class="lead">@Model.Count() invitation@(Model.Count() == 1 ? "" : "s") on record</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="/Admin/GenerateLink" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-link-45deg"></i> Generate Link
        </a>
        <a href="/Admin/InviteVendor" class="btn btn-primary btn-sm">
            <i class="bi bi-envelope"></i> Email Invite
        </a>
        <a href="/Admin/Dashboard" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="brand-panel p-0">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="icon-circle"><i class="bi bi-envelope"></i></div>
            <h6>No invitations yet</h6>
            <p>
                <a href="/Admin/InviteVendor">Send your first invitation</a> or
                <a href="/Admin/GenerateLink">generate a link</a>.
            </p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                        <tr>
                            <th>Type / Email</th>
                            <th>Company</th>
                            <th>Token</th>
                            <th>Created</th>
                            <th>Expiry Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var isExpired = item.ExpiryDate <= DateTime.Now;
                            var isActive = !isExpired && item.Status == "Pending" && !item.IsUsed;
                            var isManualLink = item.LinkType == "Manual" || item.Email?.StartsWith("manual-") == true;

                            <tr>
                                <td>
                                    @if (isManualLink)
                                    {
                                        <span class="status-chip chip-pending"><i class="bi bi-link-45deg"></i> Manual Link</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><i class="bi bi-envelope"></i> @item.Email</span>
                                    }
                                </td>
                                <td>@(string.IsNullOrEmpty(item.CompanyName) ? "-" : item.CompanyName)</td>
                                <td>
                                    <code class="bg-light p-1 rounded">@item.Token?.Substring(0, Math.Min(8, item.Token.Length))...</code>
                                </td>
                                <td>@item.CreatedAt.ToString("dd-MMM-yyyy HH:mm")</td>
                                <td>
                                    @if (isExpired)
                                    {
                                        <span class="text-danger">@item.ExpiryDate.ToString("dd-MMM-yyyy HH:mm")</span>
                                    }
                                    else
                                    {
                                        @item.ExpiryDate.ToString("dd-MMM-yyyy HH:mm")
                                    }
                                </td>
                                <td>
                                    @if (item.IsUsed) { <span class="status-chip chip-ok">Used</span> }
                                    else if (isExpired) { <span class="status-chip chip-rej">Expired</span> }
                                    else if (item.Status == "Pending") { <span class="status-chip chip-pending">Pending</span> }
                                    else { <span class="badge bg-secondary">@item.Status</span> }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        @if (isActive)
                                        {
                                            if (isManualLink)
                                            {
                                                <a href="/Admin/GetLinkDetails?token=@item.Token"
                                                   class="btn btn-info"
                                                   title="View Link"
                                                   onclick="showLinkModal(event, '@item.Token')">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <form asp-action="ResendInvitation" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-warning" title="Resend Invitation">
                                                        <i class="bi bi-envelope"></i>
                                                    </button>
                                                </form>
                                            }
                                        }
                                        <form asp-action="DeleteInvitation" method="post" class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete this invitation?');">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal for showing manual link -->
<div class="modal fade" id="linkModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background:var(--brand-accent-subtle);border-bottom-color:var(--brand-accent-soft);">
                <h5 class="modal-title" style="color:var(--brand-accent-deep);font-family:var(--font-display);font-weight:500;">
                    <i class="bi bi-link-45deg"></i> Registration Link
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info" id="modalExpiry"></div>

                <label class="form-label fw-bold">Link:</label>
                <div class="input-group mb-3">
                    <input type="text" class="form-control" id="modalLink" readonly />
                    <button class="btn btn-primary" type="button" onclick="copyModalLink()">
                        <i class="bi bi-clipboard"></i> Copy
                    </button>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Company:</label>
                    <p id="modalCompany" class="form-control-static">-</p>
                </div>

                <hr />

                <h6>Share via:</h6>
                <div class="d-flex gap-2">
                    <button class="btn btn-success btn-sm" onclick="shareWhatsApp()">
                        <i class="bi bi-whatsapp"></i> WhatsApp
                    </button>
                    <button class="btn btn-primary btn-sm" onclick="shareEmail()">
                        <i class="bi bi-envelope"></i> Email
                    </button>
                    <button class="btn btn-info btn-sm" onclick="shareTelegram()">
                        <i class="bi bi-telegram"></i> Telegram
                    </button>
                </div>

                <div class="mt-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="modalShowQR" onchange="toggleModalQR()">
                        <label class="form-check-label" for="modalShowQR">
                            Show QR Code
                        </label>
                    </div>
                    <div id="modalQRContainer" style="display: none; margin-top: 15px;" class="text-center">
                        <div id="modalQRCode"></div>
                        <p class="small text-muted mt-2">Scan to open registration link</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script>
        let currentLink = '';
        let currentToken = '';

        function showLinkModal(event, token) {
            event.preventDefault();

            fetch(`/Admin/GetLinkDetails?token=${token}`)
                .then(response => response.json())
                .then(data => {
                    currentLink = data.link;
                    currentToken = token;

                    document.getElementById('modalLink').value = data.link;
                    document.getElementById('modalCompany').textContent = data.companyName || '-';
                    document.getElementById('modalExpiry').innerHTML =
                        `<strong>Expires on:</strong> ${data.expiryDate}`;

                    var modal = new bootstrap.Modal(document.getElementById('linkModal'));
                    modal.show();
                });
        }

        function copyModalLink() {
            var copyText = document.getElementById('modalLink');
            copyText.select();
            copyText.setSelectionRange(0, 99999);
            navigator.clipboard.writeText(copyText.value);

            var btn = event.target;
            var originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-check"></i> Copied!';
            setTimeout(() => {
                btn.innerHTML = originalHtml;
            }, 2000);
        }

        function shareWhatsApp() {
            var text = encodeURIComponent('Please register as vendor using this link: ' + currentLink);
            window.open(`https://web.whatsapp.com/send?text=${text}`, '_blank');
        }

        function shareEmail() {
            var subject = encodeURIComponent('Vendor Registration Link');
            var body = encodeURIComponent('Please register using this link:\n\n' + currentLink);
            window.open(`mailto:?subject=${subject}&body=${body}`, '_blank');
        }

        function shareTelegram() {
            var url = encodeURIComponent(currentLink);
            var text = encodeURIComponent('Vendor Registration Link');
            window.open(`https://t.me/share/url?url=${url}&text=${text}`, '_blank');
        }

        function toggleModalQR() {
            var container = document.getElementById('modalQRContainer');
            var checkbox = document.getElementById('modalShowQR');

            if (checkbox.checked) {
                container.style.display = 'block';
                var qrDiv = document.getElementById('modalQRCode');
                qrDiv.innerHTML = '';
                new QRCode(qrDiv, {
                    text: currentLink,
                    width: 200,
                    height: 200
                });
            } else {
                container.style.display = 'none';
            }
        }
    </script>
}