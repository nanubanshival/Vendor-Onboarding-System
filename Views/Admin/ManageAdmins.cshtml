@model List<VendorOnboardingSystem.Models.AdminUser>
@{
    ViewData["Title"] = "Manage Admins";

    string Initials(string n)
    {
        if (string.IsNullOrWhiteSpace(n)) return "?";
        return n.Length >= 2 ? n.Substring(0, 2).ToUpper() : n.ToUpper();
    }
}

<div class="page-head d-flex justify-content-between align-items-end gap-3">
    <div>
        <span class="micro-label d-block mb-1">Access Control</span>
        <h2 class="ds-h" style="font-size:1.85rem;">Manage <em style="font-style:italic;color:var(--brand-accent);font-weight:400;">Admins</em></h2>
        <p class="lead">@Model.Count admin@(Model.Count == 1 ? "" : "s") with access to this system</p>
    </div>
    <a href="/Admin/CreateAdmin" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Admin
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="brand-panel p-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Admin</th>
                    <th>Role</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="brand-avatar sm">@Initials(a.Username)</div>
                            <div>
                                <div class="fw-semibold">@a.Username</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        @if (a.IsSuperAdmin) { <span class="status-chip chip-new"><i class="bi bi-shield-fill-check"></i> Super Admin</span> }
                        else { <span class="status-chip chip-ok"><i class="bi bi-shield-check"></i> Admin</span> }
                    </td>
                    <td class="text-end">
                        @if (!a.IsSuperAdmin)
                        {
                            <form asp-action="DeleteAdmin" method="post" class="d-inline" onsubmit="return confirm('Delete this admin?')">
                                <input type="hidden" name="id" value="@a.AdminUserId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        }
                        else { <span class="text-muted small">—</span> }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
