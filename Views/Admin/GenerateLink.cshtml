@model VendorOnboardingSystem.ViewModels.GenerateLinkVM
@{
    ViewData["Title"] = "Generate Registration Link";
}

<div class="container py-4" style="max-width:1000px;">
    <div class="page-head d-flex justify-content-between align-items-end gap-3">
        <div>
            <span class="micro-label d-block mb-1">Manual Link</span>
            <h2 class="ds-h" style="font-size:1.85rem;">Generate <em style="font-style:italic;color:var(--brand-accent);font-weight:400;">Registration Link</em></h2>
            <p class="lead">Create a unique registration link to share via WhatsApp, email, or any channel</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Admin/InviteVendor" class="btn btn-outline-secondary btn-sm"><i class="bi bi-envelope"></i> Email Invite</a>
            <a href="/Admin/Invitations" class="btn btn-outline-secondary btn-sm"><i class="bi bi-list-ul"></i> All Links</a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="brand-panel">
                <form asp-action="GenerateLink" method="post">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CompanyName" class="form-label">Company Name <span class="text-muted">(optional)</span></label>
                        <input asp-for="CompanyName" class="form-control" placeholder="e.g. Acme Technologies" />
                        <small class="text-muted d-block mt-1">This will be pre-filled in registration form (vendor can change it).</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ExpiryDays" class="form-label">Link Expiry <span class="text-muted">(days)</span></label>
                        <input asp-for="ExpiryDays" class="form-control" type="number" min="1" max="30" />
                        <span asp-validation-for="ExpiryDays" class="text-danger small"></span>
                        <small class="text-muted d-block mt-1">Link will expire after this many days.</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Internal Notes <span class="text-muted">(optional)</span></label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Any internal notes for your reference..."></textarea>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-link-45deg me-1"></i> Generate Link
                        </button>
                        <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="brand-panel" style="background:var(--brand-accent-subtle);border-color:var(--brand-accent-soft);">
                <span class="micro-label d-block mb-2">How to use</span>
                <ol class="mb-3 small ps-3" style="line-height:1.9;">
                    <li>Fill company name (optional)</li>
                    <li>Set expiry days (default 7)</li>
                    <li>Click <strong>Generate Link</strong></li>
                    <li>Copy the generated link</li>
                    <li>Share via WhatsApp, Email, or any channel</li>
                </ol>
                <hr class="brand-divider" />
                <p class="small text-muted mb-0">
                    <i class="bi bi-shield-check me-1" style="color:var(--brand-accent);"></i>
                    Each link is unique and expires automatically.
                </p>
            </div>
        </div>
    </div>
</div>
