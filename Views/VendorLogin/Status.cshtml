@model VendorOnboardingSystem.ViewModels.VendorStatusVM
@{
    ViewData["Title"] = "Application Status";
    var v = Model.Vendor;
    var pending = Model.PendingEditRequest;

    string SectionLabel(string key) => key switch
    {
        "LegalInfo" => "Legal Information",
        "PANDetails" => "PAN Details",
        "GSTDetails" => "GST Details",
        "MSMEDetails" => "MSME Details",
        "TDSDetails" => "TDS Details",
        "BankDetails" => "Bank Details",
        "AddressDetails" => "Address Details",
        "ContactDetails" => "Contact Information",
        _ => key
    };

    string SectionIcon(string key) => key switch
    {
        "LegalInfo" => "bi-file-earmark-text",
        "PANDetails" => "bi-credit-card-2-front",
        "GSTDetails" => "bi-receipt",
        "MSMEDetails" => "bi-building",
        "TDSDetails" => "bi-cash-coin",
        "BankDetails" => "bi-bank",
        "AddressDetails" => "bi-geo-alt",
        "ContactDetails" => "bi-person-lines-fill",
        _ => "bi-folder"
    };

    string StatusBadgeClass(string status) => status switch
    {
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        "Changes Requested" => "bg-warning text-dark",
        "Changes Submitted" => "bg-info text-dark",
        "PendingSuperAdmin" => "bg-info text-dark",
        _ => "bg-secondary"
    };

    string StatusFriendly(string status) => status switch
    {
        "PendingSuperAdmin" => "Awaiting Super Admin",
        _ => status
    };
}

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">My Application</h3>
            <p class="text-muted mb-0">
                <span class="me-3"><i class="bi bi-hash"></i> @v.ReferenceNumber</span>
                <span class="badge @StatusBadgeClass(v.Status)">@StatusFriendly(v.Status)</span>
            </p>
        </div>
        <a href="/VendorLogin/Logout" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Quick stats row -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted d-block">Submitted On</small>
                    <span class="fw-semibold">@v.CreatedAt.ToString("dd MMM yyyy")</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted d-block">Change Rounds</small>
                    <span class="fw-semibold">@Model.ChangesRequestedCount requested · @Model.ChangesCompletedCount completed</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted d-block">Last Activity</small>
                    <span class="fw-semibold">@(Model.LastActivityAt?.ToString("dd MMM yyyy, hh:mm tt") ?? "—")</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted d-block">Vendor Code</small>
                    <span class="fw-semibold">@(string.IsNullOrEmpty(v.VendorCode) ? "—" : v.VendorCode)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Action banner if pending edits -->
    @if (Model.HasPendingEditRequest)
    {
        var sections = pending.FieldsToUpdate?.Split(',', StringSplitOptions.RemoveEmptyEntries) ?? new string[0];
        Dictionary<string, string> sectionComments = new();
        if (!string.IsNullOrEmpty(pending.FieldComments))
        {
            try { sectionComments = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(pending.FieldComments); }
            catch { }
        }

        <div class="alert alert-warning border-warning shadow-sm mb-4">
            <div class="d-flex">
                <i class="bi bi-exclamation-triangle-fill fs-2 text-warning me-3"></i>
                <div class="flex-grow-1">
                    <h5 class="alert-heading fw-bold mb-2">Action Required</h5>
                    <p class="mb-2">Admin requested changes on <strong>@pending.RequestDate.ToString("dd MMM yyyy, hh:mm tt")</strong>. Please review and resubmit.</p>
                    @if (!string.IsNullOrEmpty(pending.AdminNotes))
                    {
                        <div class="bg-white rounded p-2 mb-2 small"><strong>Admin note:</strong> @pending.AdminNotes</div>
                    }
                    @if (sections.Any())
                    {
                        <div class="mb-2">
                            @foreach (var s in sections)
                            {
                                <span class="badge bg-light text-dark border me-1 mb-1">
                                    <i class="@SectionIcon(s)"></i> @SectionLabel(s)
                                </span>
                            }
                        </div>
                    }
                    <a href="/Vendor/EditRequest/@pending.Id" class="btn btn-warning btn-sm fw-semibold">
                        <i class="bi bi-pencil-square me-1"></i>Update Now
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-3" id="statusTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#overview" type="button">
                <i class="bi bi-speedometer2 me-1"></i>Overview
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#submission" type="button">
                <i class="bi bi-file-earmark-text me-1"></i>My Submission
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#timeline" type="button">
                <i class="bi bi-clock-history me-1"></i>Activity Timeline
                <span class="badge bg-secondary ms-1">@Model.Timeline.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content">

        <!-- ===== OVERVIEW TAB ===== -->
        <div class="tab-pane fade show active" id="overview">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        @switch (v.Status)
                        {
                            case "Approved":
                                <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex p-3"><i class="bi bi-check-circle-fill fs-1"></i></div>
                                <h3 class="fw-bold mt-3 text-success">Application Approved</h3>
                                break;
                            case "Rejected":
                                <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex p-3"><i class="bi bi-x-circle-fill fs-1"></i></div>
                                <h3 class="fw-bold mt-3 text-danger">Application Rejected</h3>
                                break;
                            case "Changes Requested":
                                <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex p-3"><i class="bi bi-pencil-square fs-1"></i></div>
                                <h3 class="fw-bold mt-3 text-warning">Changes Requested</h3>
                                break;
                            case "Changes Submitted":
                                <div class="bg-info bg-opacity-10 text-info rounded-circle d-inline-flex p-3"><i class="bi bi-hourglass-split fs-1"></i></div>
                                <h3 class="fw-bold mt-3 text-info">Updates Under Review</h3>
                                break;
                            case "PendingSuperAdmin":
                                <div class="bg-info bg-opacity-10 text-info rounded-circle d-inline-flex p-3"><i class="bi bi-shield-check fs-1"></i></div>
                                <h3 class="fw-bold mt-3 text-info">Awaiting Super Admin</h3>
                                break;
                            default:
                                <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex p-3"><i class="bi bi-hourglass-split fs-1"></i></div>
                                <h3 class="fw-bold mt-3 text-warning">Under Review</h3>
                                break;
                        }
                        <p class="text-muted mt-2 mb-0">Reference: <span class="fw-semibold">@v.ReferenceNumber</span></p>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded">
                                <small class="text-muted d-block">Legal Name</small>
                                <span class="fw-semibold">@v.LegalName</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded">
                                <small class="text-muted d-block">Trade Name</small>
                                <span class="fw-semibold">@(string.IsNullOrEmpty(v.TradeName) ? "—" : v.TradeName)</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded">
                                <small class="text-muted d-block">Email</small>
                                <span class="fw-semibold">@v.Email</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded">
                                <small class="text-muted d-block">PAN</small>
                                <span class="fw-semibold">@v.PAN</span>
                            </div>
                        </div>

                        @if (v.Status == "Approved" && !string.IsNullOrEmpty(v.VendorCode))
                        {
                            <div class="col-12">
                                <div class="bg-success bg-opacity-10 p-3 rounded text-center">
                                    <small class="text-success d-block">Your Vendor Code</small>
                                    <span class="fw-bold fs-4">@v.VendorCode</span>
                                </div>
                            </div>
                        }

                        @if (v.Status == "Rejected" && !string.IsNullOrEmpty(v.RejectionReason))
                        {
                            <div class="col-12">
                                <div class="bg-danger bg-opacity-10 p-3 rounded">
                                    <small class="text-danger d-block">Rejection Reason</small>
                                    <span class="fw-semibold">@v.RejectionReason</span>
                                </div>
                            </div>
                        }
                    </div>

                    <p class="small text-muted text-center mt-4 mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Last login: @(v.LastLoginAt?.ToString("dd MMM yyyy, hh:mm tt") ?? "First time")
                    </p>
                </div>
            </div>
        </div>

        <!-- ===== MY SUBMISSION TAB ===== -->
        <div class="tab-pane fade" id="submission">
            @await Html.PartialAsync("_SubmissionDetails", v)
        </div>

        <!-- ===== TIMELINE TAB ===== -->
        <div class="tab-pane fade" id="timeline">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    @if (!Model.Timeline.Any())
                    {
                        <p class="text-muted text-center my-5">No activity yet.</p>
                    }
                    else
                    {
                        <div class="timeline">
                            @foreach (var ev in Model.Timeline)
                            {
                                <div class="tl-item">
                                    <div class="tl-marker bg-@ev.Color text-white">
                                        <i class="bi @ev.Icon"></i>
                                    </div>
                                    <div class="tl-content">
                                        <div class="d-flex justify-content-between flex-wrap mb-1">
                                            <h6 class="fw-bold mb-0">@ev.Title</h6>
                                            <small class="text-muted">@ev.EventDate.ToString("dd MMM yyyy, hh:mm tt")</small>
                                        </div>
                                        <p class="mb-2 text-muted small">
                                            <span class="badge bg-light text-dark border me-1">@ev.Actor</span>
                                            @ev.Description
                                        </p>

                                        @if (!string.IsNullOrEmpty(ev.Notes))
                                        {
                                            <div class="bg-light rounded p-2 small mb-2">
                                                <strong>Note:</strong> @ev.Notes
                                            </div>
                                        }

                                        @if (ev.AffectedSections.Any())
                                        {
                                            <div class="mb-2">
                                                @foreach (var s in ev.AffectedSections)
                                                {
                                                    <span class="badge bg-light text-dark border me-1 mb-1">
                                                        <i class="@SectionIcon(s)"></i> @SectionLabel(s)
                                                    </span>
                                                }
                                            </div>
                                        }

                                        @if (ev.SectionComments != null && ev.SectionComments.Any(c => !string.IsNullOrEmpty(c.Value)))
                                        {
                                            <details class="small">
                                                <summary class="text-primary" style="cursor:pointer">View admin comments per section</summary>
                                                <ul class="list-unstyled mt-2 mb-0">
                                                    @foreach (var kv in ev.SectionComments.Where(c => !string.IsNullOrEmpty(c.Value)))
                                                    {
                                                        <li class="bg-light rounded p-2 mb-1">
                                                            <strong>@SectionLabel(kv.Key):</strong> @kv.Value
                                                        </li>
                                                    }
                                                </ul>
                                            </details>
                                        }

                                        @if (ev.EventType == "EditsRequested" && ev.EditRequestId.HasValue
                                             && Model.PendingEditRequest != null && Model.PendingEditRequest.Id == ev.EditRequestId.Value)
                                        {
                                            <a href="/Vendor/EditRequest/@ev.EditRequestId" class="btn btn-warning btn-sm mt-2">
                                                <i class="bi bi-pencil-square"></i> Update Now
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .timeline { position: relative; padding-left: 2.5rem; }
    .timeline::before {
        content: ''; position: absolute; left: 1rem; top: 0; bottom: 0;
        width: 1px; background: var(--brand-border);
    }
    .tl-item { position: relative; padding-bottom: 1.75rem; }
    .tl-item:last-child { padding-bottom: 0; }
    .tl-marker {
        position: absolute; left: -2.5rem; top: 0;
        width: 2rem; height: 2rem; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 0 0 4px #fff;
        font-size: .85rem;
    }
    .tl-marker.bg-primary { background: var(--brand-accent) !important; }
    .tl-marker.bg-warning { background: var(--brand-warning) !important; }
    .tl-marker.bg-success { background: var(--brand-success) !important; }
    .tl-marker.bg-danger  { background: var(--brand-error) !important; }
    .tl-marker.bg-info    { background: var(--brand-info) !important; }
    .tl-content {
        background: #fff; border: 0.5px solid var(--brand-border); border-radius: 11px;
        padding: .85rem 1rem;
    }
    .tl-content h6 {
        font-family: var(--font-display); font-weight: 500;
        font-size: 1.05rem; letter-spacing: -.005em; color: var(--brand-text);
    }
</style>
