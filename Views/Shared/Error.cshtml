@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="auth-bg" style="min-height:calc(100vh - 80px);">
    <div class="brand-panel text-center" style="max-width:520px;width:100%;padding:2.5rem 2rem;">
        <div class="mx-auto mb-4 d-flex align-items-center justify-content-center rounded-circle"
             style="width:80px;height:80px;background:var(--brand-error-bg);border:0.5px solid var(--brand-error-border);">
            <i class="bi bi-exclamation-octagon" style="font-size:2.4rem;color:var(--brand-error);"></i>
        </div>

        <h2 class="ds-h mb-2" style="font-size:1.7rem;">Something <em style="font-style:italic;color:var(--brand-error);font-weight:400;">went wrong</em></h2>
        <p class="text-muted mb-4">An error occurred while processing your request. Please try again.</p>

        @if (Model.ShowRequestId)
        {
            <div class="rounded-3 p-3 mb-4" style="background:var(--brand-surface);border:0.5px solid var(--brand-border);">
                <span class="micro-label d-block mb-1">Request ID</span>
                <code class="small">@Model.RequestId</code>
            </div>
        }

        <div class="d-flex gap-2 justify-content-center">
            <a href="/" class="btn btn-outline-secondary">
                <i class="bi bi-house me-1"></i> Home
            </a>
            <a href="javascript:history.back()" class="btn btn-primary">
                <i class="bi bi-arrow-left me-1"></i> Go Back
            </a>
        </div>
    </div>
</div>
